{
	"name": "operon",
	"version": "2.6.0",
	"description": "Task management system for humans and agents with inline tasks, file tasks, filters, pipelines, pinned tasks, calendar views, Kanban views, recurrence, and time tracking.",
	"main": "main.js",
	"scripts": {
		"bundle:size": "node scripts/check-main-bundle-size.mjs",
		"bundle:size:test": "node --test scripts/check-main-bundle-size.test.mjs",
		"dev": "npm run i18n:check && node esbuild.config.mjs",
		"docs:sync": "node scripts/sync-operon-docs.mjs",
		"docs:sync-runtime:test": "node scripts/test-operon-docs-sync.mjs",
		"i18n:generate": "node scripts/generate-dense-locales.mjs --write",
		"i18n:check": "node scripts/generate-dense-locales.mjs --check",
		"i18n:test": "node --test scripts/generate-dense-locales.test.mjs scripts/dense-locales-runtime.test.mjs && npm run i18n:pack-manager:test",
		"i18n:pack-manager:test": "node scripts/run-locale-pack-manager-tests.mjs",
		"i18n:dense:generate": "npm run i18n:generate",
		"i18n:dense:check": "npm run i18n:check",
		"i18n:dense:test": "npm run i18n:test",
		"i18n:unused": "node scripts/check-unused-locale-keys.mjs",
		"i18n:unused:test": "node --test scripts/check-unused-locale-keys.test.mjs",
		"i18n:settings:test": "node scripts/run-locale-settings-migration-tests.mjs",
		"index:baseline": "node --expose-gc scripts/run-index-baseline.mjs",
		"index:v8:hydration:acceptance": "node scripts/run-index-v8-hydration-acceptance.mjs",
		"index:v8:hydration:acceptance:test": "node scripts/run-index-v8-hydration-acceptance-classifier-tests.mjs",
		"index:v8:hydration:test": "node scripts/run-index-v8-hydration-tests.mjs",
		"index:v8:incremental:test": "node scripts/run-index-v8-incremental-tests.mjs",
		"index:v8:shadow:test": "node scripts/run-index-v8-shadow-tests.mjs",
		"index:v8:storage:test": "node scripts/run-index-v8-store-tests.mjs",
		"index:v8:sync:test": "node scripts/run-index-v8-sync-tests.mjs",
		"index:v8:cutover:test": "node scripts/run-index-v8-cutover-tests.mjs",
		"index:v8:test": "node scripts/run-index-v8-contract-tests.mjs",
		"lint": "eslint . --quiet",
		"lint:report": "eslint .",
		"lint:scorecard": "eslint --config eslint.scorecard.config.mjs main.ts src",
		"lint:scorecard:strict": "eslint --config eslint.scorecard.config.mjs main.ts src --max-warnings 0",
		"lint:strict": "eslint . --max-warnings 0",
		"public-api:test": "node scripts/run-public-api-contract-tests.mjs",
		"release:check:test": "node scripts/run-release-check-tests.mjs",
		"reminder:sounds:generate": "node scripts/generate-reminder-sound-pack.mjs --write",
		"reminder:sounds:check": "node scripts/generate-reminder-sound-pack.mjs --check",
		"reminder:sounds:test": "node scripts/run-reminder-sound-pack-manager-tests.mjs",
		"reminder:scheduler:test": "node scripts/run-reminder-scheduler-tests.mjs",
		"mobile-notifications:exporter:test": "node scripts/run-mobile-notifications-exporter-tests.mjs",
		"mobile-notifications:settings:test": "node scripts/run-mobile-notifications-settings-tests.mjs",
		"build": "npm run i18n:check && npm run reminder:sounds:check && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && npm run bundle:size",
		"check": "npm run lint:strict && npm run bundle:size:test && npm run public-api:test && npm run release:check:test && npm run reminder:sounds:test && npm run reminder:scheduler:test && npm run mobile-notifications:exporter:test && npm run mobile-notifications:settings:test && npm run i18n:test && npm run i18n:settings:test && npm run i18n:unused:test && npm run i18n:unused -- --summary && npm run build",
		"release:guard": "node scripts/release-guard.mjs",
		"check:local": "npm run check && npm run index:v8:test && npm run index:v8:storage:test && npm run index:v8:shadow:test && npm run index:v8:hydration:test && npm run index:v8:incremental:test && npm run index:v8:sync:test && npm run index:v8:cutover:test && npm run index:v8:hydration:acceptance:test && npm run release:guard && npm run phase5:regression",
		"phase5:regression": "node scripts/run-phase5-regression.mjs"
	},
	"keywords": [],
	"author": "Hasan Yılmaz",
	"license": "GPL-3.0-or-later",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@eslint/json": "^2.0.0",
		"@types/node": "^16.11.6",
		"@typescript-eslint/parser": "^8.61.0",
		"esbuild": "0.28.1",
		"eslint": "^10.5.0",
		"eslint-plugin-depend": "^1.5.0",
		"eslint-plugin-obsidianmd": "^0.4.1",
		"obsidian": "1.13.0",
		"tslib": "2.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.61.0"
	},
	"dependencies": {
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "6.5.0",
		"@codemirror/view": "6.38.6",
		"ical.js": "^2.2.1"
	}
}
